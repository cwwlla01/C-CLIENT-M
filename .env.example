VITE_APP_TITLE=C-CLIENT-M
VITE_PROJECT_ROOT=/workspace/company
VITE_CCLIENT_KEY=

# optional: only for vite dev / special direct bridge debugging
VITE_BRIDGE_HTTP_ORIGIN=
VITE_BRIDGE_WS_ORIGIN=

# runtime auth for `npm run preview` / Docker
APP_LOGIN_PASSWORD=

# runtime same-origin proxy target for `server.mjs` / Docker / Vercel Functions
BRIDGE_PROXY_TARGET=http://127.0.0.1:4285
